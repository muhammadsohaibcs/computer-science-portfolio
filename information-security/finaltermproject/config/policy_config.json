{
  "_comment": "Policy Configuration for SDRCAS - Requirements: 4.3",
  "_description": "Defines role-based policies, airspace restrictions, and command type requirements",
  
  "role_policy": {
    "_description": "Role-based access control for command types",
    "command_role_requirements": {
      "MOVE": ["pilot", "admin"],
      "LAND": ["pilot", "admin"],
      "STATUS": ["pilot", "admin", "observer"],
      "EMERGENCY_STOP": ["admin"],
      "TAKEOFF": ["pilot", "admin"],
      "HOVER": ["pilot", "admin"],
      "RETURN_TO_BASE": ["pilot", "admin", "observer"]
    },
    "role_hierarchy": {
      "admin": ["pilot", "observer"],
      "pilot": ["observer"],
      "observer": []
    }
  },
  
  "drone_state_policy": {
    "_description": "Policies based on drone operational state and capabilities",
    "allowed_statuses": ["active", "idle", "hovering"],
    "blocked_statuses": ["maintenance", "error", "failsafe"],
    "capability_requirements": {
      "MOVE": ["MOVE"],
      "LAND": ["LAND"],
      "STATUS": ["STATUS"],
      "EMERGENCY_STOP": ["EMERGENCY_STOP"],
      "TAKEOFF": ["TAKEOFF"],
      "HOVER": ["HOVER"],
      "RETURN_TO_BASE": ["MOVE", "LAND"]
    },
    "state_transitions": {
      "idle": ["TAKEOFF", "STATUS"],
      "hovering": ["MOVE", "LAND", "HOVER", "STATUS", "EMERGENCY_STOP"],
      "active": ["MOVE", "LAND", "HOVER", "STATUS", "EMERGENCY_STOP", "RETURN_TO_BASE"]
    }
  },
  
  "airspace_policy": {
    "_description": "Airspace restrictions and operational limits",
    "restricted_zones": [
      {
        "name": "No-Fly Zone Alpha",
        "type": "prohibited",
        "coordinates": [[33.7, 73.1], [33.8, 73.1], [33.8, 73.2], [33.7, 73.2]],
        "altitude_max": 500,
        "reason": "Military installation"
      },
      {
        "name": "Restricted Zone Beta",
        "type": "restricted",
        "coordinates": [[33.65, 73.05], [33.75, 73.05], [33.75, 73.15], [33.65, 73.15]],
        "altitude_max": 300,
        "reason": "Civilian airport approach path",
        "allowed_roles": ["admin"]
      }
    ],
    "max_altitude": 1000,
    "min_altitude": 10,
    "max_speed": 50,
    "max_range_from_base": 5000,
    "require_justification": ["EMERGENCY_STOP"],
    "weather_restrictions": {
      "max_wind_speed": 15,
      "min_visibility": 1000,
      "prohibited_conditions": ["thunderstorm", "heavy_rain"]
    }
  },
  
  "mission_context_policy": {
    "_description": "Mission-specific authorization rules",
    "require_mission_plan": false,
    "max_mission_duration": 7200,
    "require_approval_for_commands": ["EMERGENCY_STOP"],
    "concurrent_command_limit": 1,
    "command_cooldown": {
      "EMERGENCY_STOP": 60,
      "TAKEOFF": 30
    }
  },
  
  "temporal_policy": {
    "_description": "Time-based restrictions",
    "operating_hours": {
      "enabled": false,
      "start_hour": 6,
      "end_hour": 22,
      "timezone": "UTC"
    },
    "maintenance_windows": []
  },
  
  "emergency_policy": {
    "_description": "Emergency override and failsafe policies",
    "emergency_override_roles": ["admin"],
    "emergency_commands": ["EMERGENCY_STOP", "RETURN_TO_BASE", "LAND"],
    "bypass_restrictions_on_emergency": true,
    "require_multi_approval": {
      "EMERGENCY_STOP": false
    }
  }
}
